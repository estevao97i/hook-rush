{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "useDefineForClassFields": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@hookrush/shared": ["../shared/src/index.ts"],
      "@hookrush/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "../shared/src"]
}
